// prisma/schema.prisma

// 数据源与生成器配置
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 🛡️ 枚举定义
// ==========================================
enum Role {
  PENDING
  MEMBER
  ADMIN
  OWNER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==========================================
// 🔑 NextAuth 核心验证表
// ==========================================
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ==========================================
// 👤 核心用户模型：融合原有档案与新兵架构
// ==========================================
model User {
  id            String    @id @default(cuid())
  
  // NextAuth 默认字段
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // 自定义字段
  nickname      String?
  customAvatar  String?
  
  // 船员档案信息
  githubId      String?   @unique
  githubName    String?
  realName      String?   
  studentId     String?   
  feishuLink    String?
  role          Role      @default(PENDING)
  createdAt     DateTime  @default(now())
  
  // 档案室专用显示信息（与 profile 分离，类似群昵称）
  crewNickname  String?   // 档案室显示昵称
  crewStudentId String?   // 档案室显示学号
  crewFeishuLink String?  // 档案室显示飞书链接

  // 关系映射
  accounts         Account[]
  sessions         Session[]
  attendances      Attendance[]
  leaveRequests    LeaveRequest[]
  announcements    Announcement[]
  rollCallRecords  AttendanceRecord[] 
  flightLogs       FlightLog[]        // 关联航行日志
  faqQuestions     FAQQuestion[]      // 关联FAQ提问
}

// ==========================================
// 📅 会议、签到与请假 (模块D 等)
// ==========================================
model Meeting {
  id              String       @id @default(cuid())
  title           String?
  date            DateTime     
  signInDeadline  DateTime?
  content         String?      @db.Text
  createdBy       String       
  attendances     Attendance[]
}

model Attendance {
  id        String   @id @default(cuid())
  meetingId String   
  userId    String   
  signedAt  DateTime @default(now())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model LeaveRequest {
  id        String      @id @default(cuid())
  userId    String     
  startTime DateTime    
  endTime   DateTime    
  reason    String      @db.Text
  status    LeaveStatus @default(PENDING)
  handledBy String?
  createdAt DateTime    @default(now()) 
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 🔖 导航书签 (模块A 下方等)
// ==========================================
enum BookmarkCategory {
  TOOL       // 工具类
  DOC        // 文档类
  TUTORIAL   // 教程类
  RESOURCE   // 资源类
  COMMUNITY  // 社区类
  OTHER      // 其他
}

model Bookmark {
  id          Int              @id @default(autoincrement())
  name        String
  url         String
  description String?
  category    BookmarkCategory @default(OTHER)
  iconSvg     String?          @db.Text  // 存储预抓取的 SVG 图标数据
  createdAt   DateTime         @default(now())
}

// ==========================================
// 📢 模块 A：全舰公告大屏 (Broadcast System)
// ==========================================
model Announcement {
  id        String   @id @default(cuid())
  title     String   // 广播标题
  content   String   @db.Text // 广播内容
  type      String   // 广播级别: "INFO" | "UPDATE" | "ALERT"
  isPinned  Boolean  @default(false) // 置顶状态
  authorId  String   // 发布者ID
  createdAt DateTime @default(now())

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ==========================================
// 🚀 模块 C：跃迁集结与实时签到 (Roll Call System)
// ==========================================
model RollCallSession {
  id        String   @id @default(cuid())
  creatorId String
  startTime DateTime @default(now())
  endTime   DateTime
  isActive  Boolean  @default(true)
  
  // 关联所有在此次集结中签到的记录
  records   AttendanceRecord[]
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) 
  sessionId String
  session   RollCallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade) 
  timestamp DateTime @default(now())

  // 复合唯一键，防止同一船员在同一次集结中重复签到
  @@unique([userId, sessionId])
}

// ==========================================
// 🌌 航行日志 (Flight Log System)
// ==========================================
model FlightLog {
  id        String   @id @default(cuid())
  userId    String   // 记录录入日志的指挥官 ID
  date      String   @unique // 🚀 核心：全舰每天唯一归档坐标
  title     String   
  time      String   
  content   String   @db.Text 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 🖼️ 成果档案馆 (Achievement Gallery)
// ==========================================
model GalleryImage {
  id          String   @id @default(cuid())
  imageData   String   @db.Text  // Base64 图片数据
  title       String             // 图片标题/描述
  uploaderId  String             // 上传者ID
  createdAt   DateTime @default(now())
}

// ==========================================
// ❓ FAQ 问答系统 (FAQ System)
// ==========================================
model FAQQuestion {
  id          String      @id @default(cuid())
  content     String      @db.Text   // 问题内容
  authorId    String                 // 提问者ID
  authorName  String?                // 提问者昵称
  authorImage String?                // 提问者头像
  createdAt   DateTime    @default(now())
  
  author      User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  answers     FAQAnswer[]
}

model FAQAnswer {
  id           String      @id @default(cuid())
  content      String      @db.Text   // 回答内容
  questionId   String                 // 关联问题ID
  authorId     String                 // 回答者ID
  authorName   String?                // 回答者昵称
  authorImage  String?                // 回答者头像
  authorRole   String?                // 回答者角色标识
  createdAt    DateTime    @default(now())
  
  question     FAQQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}
