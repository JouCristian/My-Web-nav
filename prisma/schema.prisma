// prisma/schema.prisma

// 数据源与生成器配置
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 🛡️ 枚举定义
// ==========================================
enum Role {
  PENDING
  MEMBER
  ADMIN
  OWNER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==========================================
// 🔑 NextAuth 核心验证表
// ==========================================
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ==========================================
// 👤 核心用户模型：融合原有档案与新兵架构
// ==========================================
model User {
  id            String    @id @default(cuid())
  
  // NextAuth 默认字段
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // 自定义字段
  nickname      String?
  customAvatar  String?
  
  // 船员档案信息
  githubId      String?   @unique
  githubName    String?
  realName      String?   
  studentId     String?   
  feishuLink    String?
  
  role          Role      @default(PENDING)
  createdAt     DateTime  @default(now())

  // 关系映射
  accounts         Account[]
  sessions         Session[]
  attendances      Attendance[]
  leaveRequests    LeaveRequest[]
  announcements    Announcement[]
  rollCallRecords  AttendanceRecord[] // 🚀 关联到跃迁集结记录
}

// ==========================================
// 📅 会议、签到与请假 (模块D 等)
// ==========================================
model Meeting {
  id              String       @id @default(cuid())
  title           String?     
  date            DateTime     
  signInDeadline  DateTime?
  content         String?      @db.Text
  createdBy       String       
  attendances     Attendance[]
}

model Attendance {
  id        String   @id @default(cuid())
  meetingId String   
  userId    String   
  signedAt  DateTime @default(now())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model LeaveRequest {
  id        String      @id @default(cuid())
  userId    String     
  startTime DateTime    // 🚀 替换了原有的单日 date
  endTime   DateTime    // 🚀 新增：归舰时间
  reason    String      @db.Text
  status    LeaveStatus @default(PENDING)
  handledBy String?
  createdAt DateTime    @default(now()) // 🚀 新增：用于排序
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 🔖 导航书签 (模块A 下方等)
// ==========================================
model Bookmark {
  id          Int      @id @default(autoincrement())
  name        String
  url         String
  description String?
  createdAt   DateTime @default(now())
}

// ==========================================
// 📢 模块 A：全舰公告大屏 (Broadcast System)
// ==========================================
model Announcement {
  id        String   @id @default(cuid())
  title     String   // 广播标题
  content   String   @db.Text // 广播内容
  type      String   // 广播级别: "INFO" | "UPDATE" | "ALERT"
  isPinned  Boolean  @default(false) // 置顶状态
  authorId  String   // 发布者ID
  createdAt DateTime @default(now())

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ==========================================
// 🚀 模块 C：跃迁集结与实时签到 (Roll Call System)
// ==========================================
model RollCallSession {
  id        String   @id @default(cuid())
  creatorId String
  startTime DateTime @default(now())
  endTime   DateTime
  isActive  Boolean  @default(true)
  
  // 关联所有在此次集结中签到的记录
  records   AttendanceRecord[]
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  userId    String
  // 🚀 核心修复 1：加上 onDelete: Cascade，当船员被开除时，自动销毁他的签到记录
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) 
  sessionId String
  // 🚀 核心修复 2：加上 onDelete: Cascade，当签到场次被删除时，自动清空该场次下的所有打卡数据
  session   RollCallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade) 
  timestamp DateTime @default(now())

  // 复合唯一键，防止同一船员在同一次集结中重复签到
  @@unique([userId, sessionId])
}