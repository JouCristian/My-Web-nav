// 数据源与生成器配置
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 🛡️ 枚举定义：系统军衔与状态 [cite: 85-87, 143-145]
// ==========================================

enum Role {
  PENDING  // Lv0 新兵
  MEMBER   // Lv1 船员
  ADMIN    // Lv2 领航员
  OWNER    // Lv3 舰长
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==========================================
// 👤 核心用户模型：船员档案室 [cite: 62-91]
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  githubId      String?   @unique
  githubName    String?
  avatarUrl     String?
  
  // 船员实名信息 [cite: 76-84]
  realName      String?   
  studentId     String?   
  feishuLink    String?   
  
  role          Role      @default(PENDING)
  createdAt     DateTime  @default(now())

  // 关系映射 [cite: 92-94]
  attendances   Attendance[]
  leaveRequests LeaveRequest[]
}

// ==========================================
// 📅 会议与签到：跃迁集结系统 [cite: 97-131]
// ==========================================

model Meeting {
  id              String       @id @default(cuid())
  title           String?     
  date            DateTime     
  signInDeadline  DateTime?    
  content         String?      @db.Text
  createdBy       String       

  attendances     Attendance[]
}

model Attendance {
  id        String   @id @default(cuid())
  meetingId String   
  userId    String   
  signedAt  DateTime @default(now())

  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

// ==========================================
// 📝 请假申请：双端审批子系统 [cite: 134-152]
// ==========================================

model LeaveRequest {
  id        String      @id @default(cuid())
  userId    String     
  date      DateTime    
  reason    String      @db.Text
  status    LeaveStatus @default(PENDING)
  
  handledBy String?     

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 🔖 原有书签功能（保留）
// ==========================================

model Bookmark {
  id          Int      @id @default(autoincrement())
  name        String
  url         String
  description String?
  createdAt   DateTime @default(now())
}