// 数据源与生成器配置
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 🛡️ 枚举定义
// ==========================================
enum Role {
  PENDING
  MEMBER
  ADMIN
  OWNER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==========================================
// 🔑 NextAuth 核心验证表 (绝不能删)
// ==========================================
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ==========================================
// 👤 核心用户模型：融合原有档案与新兵架构
// ==========================================
model User {
  id            String    @id @default(cuid())
  
  // NextAuth 默认字段
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // 你原有的自定义字段 (保留！)
  nickname      String?
  customAvatar  String?
  
  // 《白皮书》新增的船员档案信息
  githubId      String?   @unique
  githubName    String?
  realName      String?   
  studentId     String?   
  feishuLink    String?   
  
  role          Role      @default(PENDING)
  createdAt     DateTime  @default(now())

  // 关系映射
  accounts      Account[]
  sessions      Session[]
  attendances   Attendance[]
  leaveRequests LeaveRequest[]
}

// ==========================================
// 📅 会议、签到与请假 (白皮书架构)
// ==========================================
model Meeting {
  id              String       @id @default(cuid())
  title           String?     
  date            DateTime     
  signInDeadline  DateTime?    
  content         String?      @db.Text
  createdBy       String       
  attendances     Attendance[]
}

model Attendance {
  id        String   @id @default(cuid())
  meetingId String   
  userId    String   
  signedAt  DateTime @default(now())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model LeaveRequest {
  id        String      @id @default(cuid())
  userId    String     
  date      DateTime    
  reason    String      @db.Text
  status    LeaveStatus @default(PENDING)
  handledBy String?     
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 🔖 导航书签 (保留)
// ==========================================
model Bookmark {
  id          Int      @id @default(autoincrement())
  name        String
  url         String
  description String?
  createdAt   DateTime @default(now())
}